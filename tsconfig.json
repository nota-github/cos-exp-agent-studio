{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@server/*": ["./packages/server/src/*"],
      "@client/*": ["./packages/client/src/*"]
    }
  },
  "exclude": ["node_modules", "**/dist"]
}
